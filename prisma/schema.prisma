// ============================================================================
// PoultryFarm Pro — Complete Schema v2.0
// Multi-tenant SaaS | 16 Modules | Layer + Broiler separation
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MODULE 0 — PLATFORM / SAAS INFRASTRUCTURE
// ============================================================================

model Tenant {
  id               String       @id @default(uuid())
  farmName         String
  subdomain        String       @unique
  country          String       @db.Char(2)
  timezone         String       @default("Africa/Lagos")
  defaultCurrency  Currency     @default(NGN)
  secondaryCurrency Currency?
  exchangeRate     Decimal?     @db.Decimal(10,4)   // secondary per primary
  logoUrl          String?
  brandingConfig   Json?
  address          String?
  phone            String?
  email            String?
  status           TenantStatus @default(TRIAL)
  // Add-on modules activated for this tenant
  hasHatchery      Boolean      @default(false)
  hasFeedMill      Boolean      @default(false)
  hasProcessingPlant Boolean    @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  subscription        Subscription?
  users               User[]
  farms               Farm[]
  plans               Plan[]       @relation("TenantPlans")
  auditLogs           AuditLog[]
  notifications       Notification[]
  alertRules          AlertRule[]
  currencies          TenantCurrency[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum Currency {
  NGN
  USD
  GBP
  EUR
  GHS
  KES
  ZAR
}

// ─── SaaS Plans ──────────────────────────────────────────────────────────────

model Plan {
  id            String   @id @default(uuid())
  name          String
  maxBirds      Int
  maxUsers      Int
  maxFarms      Int      @default(1)
  monthlyPrice  Decimal  @db.Decimal(10,2)
  annualPrice   Decimal  @db.Decimal(10,2)
  features      Json     // array of FeatureFlag strings
  isPublic      Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
  tenants       Tenant[]  @relation("TenantPlans")

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique
  planId               String
  stripeSubscriptionId String?
  stripeCustomerId     String?
  billingCycle         BillingCycle       @default(MONTHLY)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelledAt          DateTime?
  status               SubscriptionStatus @default(TRIALING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  plan     Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model TenantCurrency {
  id           String   @id @default(uuid())
  tenantId     String
  currency     Currency
  exchangeRate Decimal  @db.Decimal(10,4)
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, currency])
  @@map("tenant_currencies")
}

// ============================================================================
// MODULE 1 — USER & ROLE MANAGEMENT
// ============================================================================

model User {
  id              String    @id @default(uuid())
  tenantId        String
  farmId          String?   // null = access to all farms (Farm Admin, Farm Manager)
  email           String
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  avatarUrl       String?
  role            UserRole  @default(PEN_WORKER)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                Tenant              @relation(fields: [tenantId], references: [id])
  farm                  Farm?               @relation(fields: [farmId], references: [id])
  penAssignments        PenWorkerAssignment[]
  tasksAssigned         Task[]              @relation("TaskAssignedTo")
  tasksCreated          Task[]              @relation("TaskCreatedBy")
  tasksApproved         Task[]              @relation("TaskApprovedBy")
  mortalityRecords      MortalityRecord[]
  feedConsumptionRecords FeedConsumption[]
  eggProductionRecords  EggProduction[]
  weightRecords         WeightRecord[]
  broilerHarvestRecords BroilerHarvest[]
  vaccinationsAdministered Vaccination[]
  medicationLogs        MedicationLog[]
  healthObservations    HealthObservation[]
  vetVisits             VetVisit[]
  dailyReports          DailyReport[]       @relation("ReportSubmittedBy")
  dailyReportsApproved  DailyReport[]       @relation("ReportApprovedBy")
  storeReceipts         StoreReceipt[]
  storeIssuances        StoreIssuance[]
  purchaseRequisitions  PurchaseRequisition[]
  purchaseOrders        PurchaseOrder[]     @relation("POCreatedBy")
  purchaseOrdersApproved PurchaseOrder[]    @relation("POApprovedBy")
  salesOrders           SalesOrder[]
  payments              Payment[]
  payrollRecords        PayrollRecord[]
  attendanceRecords     AttendanceRecord[]
  leaveRequests         LeaveRequest[]      @relation("LeaveRequestedBy")
  leaveApprovals        LeaveRequest[]      @relation("LeaveApprovedBy")
  maintenanceRequests   MaintenanceRequest[]
  workOrders            WorkOrder[]         @relation("WOAssignedTo")
  workOrdersCreated     WorkOrder[]         @relation("WOCreatedBy")
  feedMillBatches       FeedMillBatch[]
  qcTests               QCTest[]
  verifications         Verification[]
  auditLogs             AuditLog[]
  notifications         Notification[]      @relation("NotificationRecipient")
  sentNotifications     Notification[]      @relation("NotificationSender")
  biosecurityLogs       BiosecurityLog[]
  staffProfile          StaffProfile?

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  // Platform level
  SUPER_ADMIN          // SaaS platform admin
  CHAIRPERSON          // Top-level org oversight
  // Farm admin level
  FARM_ADMIN           // System config, user management
  // Operations
  FARM_MANAGER         // Oversees all farm operations
  STORE_MANAGER        // Verification & store oversight
  FEED_MILL_MANAGER    // Feed mill operations
  PEN_MANAGER          // Supervises assigned pens
  // Staff level
  STORE_CLERK          // Logs incoming/outgoing goods
  PRODUCTION_STAFF     // Feed mill production
  QC_TECHNICIAN        // Feed quality testing
  PEN_WORKER           // Daily data entry
}

// Pen worker assignments (workers can be assigned to multiple sections)
model PenWorkerAssignment {
  id           String   @id @default(uuid())
  userId       String
  penSectionId String
  assignedAt   DateTime @default(now())
  isActive     Boolean  @default(true)

  user       User       @relation(fields: [userId], references: [id])
  penSection PenSection @relation(fields: [penSectionId], references: [id])

  @@unique([userId, penSectionId])
  @@map("pen_worker_assignments")
}

// ============================================================================
// MODULE 2 — FARM STRUCTURE
// A tenant can have multiple farms (multi-farm SaaS support)
// ============================================================================

model Farm {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  location    String?
  address     String?
  phone       String?
  email       String?
  managerId   String?  // Farm Manager user id
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  users   User[]
  pens    Pen[]
  stores  Store[]
  feedMillBatches FeedMillBatch[]
  productionTargets ProductionTarget[]
  dailyReports DailyReport[]

  @@map("farms")
}

model Pen {
  id          String   @id @default(uuid())
  farmId      String
  name        String
  operationType PenOperationType  // LAYER or BROILER — strict separation
  capacity    Int
  location    String?
  buildYear   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  farm     Farm         @relation(fields: [farmId], references: [id])
  sections PenSection[]

  @@map("pens")
}

enum PenOperationType {
  LAYER
  BROILER
  BREEDER   // future
  TURKEY    // future
}

model PenSection {
  id          String  @id @default(uuid())
  penId       String
  name        String  // Section A, B, C, D
  capacity    Int
  isActive    Boolean @default(true)

  pen                  Pen                   @relation(fields: [penId], references: [id])
  workerAssignments    PenWorkerAssignment[]
  flocks               Flock[]
  mortalityRecords     MortalityRecord[]
  feedConsumption      FeedConsumption[]
  eggProduction        EggProduction[]
  broilerHarvests      BroilerHarvest[]
  weightRecords        WeightRecord[]
  tasks                Task[]
  healthObservations   HealthObservation[]
  storeIssuances       StoreIssuance[]
  dailyReports         DailyReport[]

  @@map("pen_sections")
}

// ============================================================================
// MODULE 2A — FLOCK MANAGEMENT (LAYER & BROILER SEPARATED)
// ============================================================================

model Flock {
  id                  String      @id @default(uuid())
  tenantId            String
  penSectionId        String
  batchCode           String
  operationType       PenOperationType  // Must match pen's operationType
  breed               String
  dateOfPlacement     DateTime    @db.Date
  initialCount        Int
  currentCount        Int
  source              FlockSource @default(PURCHASED)
  purchaseCost        Decimal?    @db.Decimal(14,2)
  purchaseCurrency    Currency    @default(NGN)
  status              FlockStatus @default(ACTIVE)
  notes               String?

  // Layer-specific fields
  expectedLayingStartDate DateTime? @db.Date
  peakLayingRatePct       Decimal?  @db.Decimal(5,2)
  depletionDate           DateTime? @db.Date  // when flock will be sold as spent hens

  // Broiler-specific fields
  targetWeightG           Decimal?  @db.Decimal(8,2)
  expectedHarvestDate     DateTime? @db.Date
  targetFCR               Decimal?  @db.Decimal(4,2)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  penSection           PenSection         @relation(fields: [penSectionId], references: [id])
  mortalityRecords     MortalityRecord[]
  feedConsumption      FeedConsumption[]
  eggProduction        EggProduction[]    // layers only
  broilerHarvests      BroilerHarvest[]   // broilers only
  weightRecords        WeightRecord[]     // broilers primarily
  vaccinations         Vaccination[]
  medicationLogs       MedicationLog[]
  healthObservations   HealthObservation[]
  dailyReports         DailyReport[]
  salesOrderItems      SalesOrderItem[]

  @@unique([tenantId, batchCode])
  @@map("flocks")
}

enum FlockStatus {
  ACTIVE
  HARVESTED
  DEPLETED   // layers — end of lay cycle
  CULLED
  SOLD
  TRANSFERRED
}

enum FlockSource {
  OWN_HATCHERY
  PURCHASED
  TRANSFERRED
}

// ─── LAYER PRODUCTION ────────────────────────────────────────────────────────

model EggProduction {
  id              String   @id @default(uuid())
  flockId         String
  penSectionId    String
  collectionDate  DateTime @db.Date
  // Counts
  totalEggs       Int
  gradeACount     Int      @default(0)
  gradeBCount     Int      @default(0)
  crackedCount    Int      @default(0)
  dirtyCount      Int      @default(0)
  // Calculated
  layingRatePct   Decimal  @db.Decimal(5,2)
  // Packaging
  cratesCount     Int?     // 1 crate = 30 eggs
  // Submission flow
  recordedById    String
  approvedById    String?
  approvedAt      DateTime?
  submissionStatus SubmissionStatus @default(PENDING)
  notes           String?
  createdAt       DateTime @default(now())

  flock      Flock      @relation(fields: [flockId], references: [id])
  penSection PenSection @relation(fields: [penSectionId], references: [id])
  recordedBy User       @relation(fields: [recordedById], references: [id])

  @@map("egg_production")
}

// ─── BROILER PRODUCTION ───────────────────────────────────────────────────────

model WeightRecord {
  id            String   @id @default(uuid())
  flockId       String
  penSectionId  String
  recordDate    DateTime @db.Date
  ageInDays     Int
  sampleSize    Int
  avgWeightG    Decimal  @db.Decimal(8,2)
  minWeightG    Decimal  @db.Decimal(8,2)
  maxWeightG    Decimal  @db.Decimal(8,2)
  uniformityPct Decimal? @db.Decimal(5,2)  // % birds within 10% of avg
  recordedById  String
  notes         String?
  createdAt     DateTime @default(now())

  flock      Flock      @relation(fields: [flockId], references: [id])
  penSection PenSection @relation(fields: [penSectionId], references: [id])
  recordedBy User       @relation(fields: [recordedById], references: [id])

  @@map("weight_records")
}

model BroilerHarvest {
  id              String   @id @default(uuid())
  flockId         String
  penSectionId    String
  harvestDate     DateTime @db.Date
  // Bird counts
  birdsHarvested  Int
  birdsRejected   Int      @default(0)
  // Weights
  totalLiveWeightKg  Decimal @db.Decimal(10,2)
  avgLiveWeightG     Decimal @db.Decimal(8,2)
  totalDressWeightKg Decimal? @db.Decimal(10,2)
  dressingPct        Decimal? @db.Decimal(5,2)
  // Grading
  grade1Count     Int      @default(0)
  grade2Count     Int      @default(0)
  grade3Count     Int      @default(0)
  // FCR at harvest
  finalFCR        Decimal? @db.Decimal(5,3)
  totalFeedKg     Decimal? @db.Decimal(10,2)
  // Financials
  pricePerKg      Decimal? @db.Decimal(10,2)
  totalRevenue    Decimal? @db.Decimal(14,2)
  currency        Currency @default(NGN)
  // Submission
  recordedById    String
  approvedById    String?
  approvedAt      DateTime?
  submissionStatus SubmissionStatus @default(PENDING)
  notes           String?
  createdAt       DateTime @default(now())

  flock      Flock      @relation(fields: [flockId], references: [id])
  penSection PenSection @relation(fields: [penSectionId], references: [id])
  recordedBy User       @relation(fields: [recordedById], references: [id])

  @@map("broiler_harvests")
}

// ─── MORTALITY ────────────────────────────────────────────────────────────────

model MortalityRecord {
  id              String        @id @default(uuid())
  flockId         String
  penSectionId    String
  recordedById    String
  recordDate      DateTime      @db.Date
  count           Int
  causeCode       MortalityCause @default(UNKNOWN)
  notes           String?
  photoUrl        String?
  approvedById    String?
  approvedAt      DateTime?
  submissionStatus SubmissionStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  flock      Flock      @relation(fields: [flockId], references: [id])
  penSection PenSection @relation(fields: [penSectionId], references: [id])
  recordedBy User       @relation(fields: [recordedById], references: [id])

  @@map("mortality_records")
}

enum MortalityCause {
  DISEASE
  INJURY
  CULLED
  UNKNOWN
  HEAT_STRESS
  FEED_ISSUE
  PREDATOR
  WATER_ISSUE
  RESPIRATORY
}

enum SubmissionStatus {
  PENDING    // submitted by worker, awaiting approval
  APPROVED   // pen manager approved
  REJECTED   // pen manager rejected, needs resubmission
  VERIFIED   // store manager verified
}

// ─── DAILY REPORTS (approval workflow) ───────────────────────────────────────

model DailyReport {
  id              String           @id @default(uuid())
  farmId          String
  penSectionId    String
  flockId         String?
  reportDate      DateTime         @db.Date
  operationType   PenOperationType
  // Summary fields (auto-calculated from individual records)
  totalMortality  Int              @default(0)
  totalFeedKg     Decimal          @db.Decimal(10,2) @default(0)
  totalEggs       Int?             // layers
  layingRatePct   Decimal?         @db.Decimal(5,2)  // layers
  avgWeightG      Decimal?         @db.Decimal(8,2)  // broilers
  observations    String?
  // Workflow
  submittedById   String
  submittedAt     DateTime         @default(now())
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  status          SubmissionStatus @default(PENDING)

  farm        Farm       @relation(fields: [farmId], references: [id])
  penSection  PenSection @relation(fields: [penSectionId], references: [id])
  flock       Flock?     @relation(fields: [flockId], references: [id])
  submittedBy User       @relation("ReportSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?      @relation("ReportApprovedBy", fields: [approvedById], references: [id])

  @@unique([penSectionId, reportDate])
  @@map("daily_reports")
}

// ============================================================================
// MODULE 3 — FEED MANAGEMENT (External Supply + Optional Mill)
// ============================================================================

model FeedFormula {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g. "Layer Starter Phase 1"
  birdType    PenOperationType
  ageWeekMin  Int
  ageWeekMax  Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  ingredients FeedFormulaIngredient[]
  feedInventory FeedInventory[]

  @@map("feed_formulas")
}

model FeedFormulaIngredient {
  id          String   @id @default(uuid())
  formulaId   String
  ingredient  String   // e.g. "Maize", "Soybean Meal"
  percentagePct Decimal @db.Decimal(5,2)

  formula FeedFormula @relation(fields: [formulaId], references: [id])

  @@map("feed_formula_ingredients")
}

model FeedInventory {
  id               String    @id @default(uuid())
  tenantId         String
  storeId          String
  feedType         String
  formulaId        String?
  currentStockKg   Decimal   @db.Decimal(12,2)
  reorderLevelKg   Decimal   @db.Decimal(10,2)
  maxStockKg       Decimal?  @db.Decimal(12,2)
  costPerKg        Decimal   @db.Decimal(10,4)
  currency         Currency  @default(NGN)
  supplierId       String?
  batchNumber      String?
  expiryDate       DateTime? @db.Date
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  store         Store            @relation(fields: [storeId], references: [id])
  formula       FeedFormula?     @relation(fields: [formulaId], references: [id])
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  consumption   FeedConsumption[]
  storeReceipts StoreReceipt[]   @relation("FeedReceipts")
  issuances     StoreIssuance[]  @relation("FeedIssuances")

  @@map("feed_inventory")
}

model FeedConsumption {
  id              String   @id @default(uuid())
  flockId         String
  penSectionId    String
  feedInventoryId String
  recordedDate    DateTime @db.Date
  quantityKg      Decimal  @db.Decimal(10,2)
  gramsPerBird    Decimal? @db.Decimal(6,2)  // auto-calculated
  costAtTime      Decimal  @db.Decimal(10,4)
  currency        Currency @default(NGN)
  recordedById    String
  notes           String?
  createdAt       DateTime @default(now())

  flock         Flock         @relation(fields: [flockId], references: [id])
  penSection    PenSection    @relation(fields: [penSectionId], references: [id])
  feedInventory FeedInventory @relation(fields: [feedInventoryId], references: [id])
  recordedBy    User          @relation(fields: [recordedById], references: [id])

  @@map("feed_consumption")
}

// ─── FEED MILL (add-on module) ────────────────────────────────────────────────

model FeedMillBatch {
  id              String          @id @default(uuid())
  tenantId        String
  farmId          String
  batchCode       String
  formulaId       String?
  targetQuantityKg Decimal        @db.Decimal(12,2)
  actualQuantityKg Decimal?       @db.Decimal(12,2)
  productionDate  DateTime        @db.Date
  status          FeedMillStatus  @default(PLANNED)
  producedById    String?
  qcStatus        QCStatus        @default(PENDING)
  qcCertifiedById String?
  qcCertifiedAt   DateTime?
  releasedToStoreAt DateTime?
  costPerKg       Decimal?        @db.Decimal(10,4)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  farm          Farm      @relation(fields: [farmId], references: [id])
  producedBy    User?     @relation(fields: [producedById], references: [id])
  qcTests       QCTest[]

  @@unique([tenantId, batchCode])
  @@map("feed_mill_batches")
}

enum FeedMillStatus {
  PLANNED
  IN_PRODUCTION
  PRODUCED
  QC_PASSED
  QC_FAILED
  RELEASED
  REJECTED
}

model QCTest {
  id              String    @id @default(uuid())
  feedMillBatchId String
  testType        String    // e.g. "Moisture", "Protein", "Aflatoxin"
  testedById      String
  testDate        DateTime  @db.Date
  result          String
  passedSpec      Boolean
  specMin         Decimal?  @db.Decimal(8,4)
  specMax         Decimal?  @db.Decimal(8,4)
  notes           String?
  createdAt       DateTime  @default(now())

  feedMillBatch FeedMillBatch @relation(fields: [feedMillBatchId], references: [id])
  testedBy      User          @relation(fields: [testedById], references: [id])

  @@map("qc_tests")
}

enum QCStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  WAIVED
}

// ============================================================================
// MODULE 4 — INVENTORY MANAGEMENT
// ============================================================================

model Store {
  id          String    @id @default(uuid())
  farmId      String
  name        String    // e.g. "Main Feed Store", "Medication Store"
  storeType   StoreType
  managerId   String?
  location    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  farm          Farm            @relation(fields: [farmId], references: [id])
  feedInventory FeedInventory[]
  inventory     InventoryItem[]
  receipts      StoreReceipt[]
  issuances     StoreIssuance[]
  verifications Verification[]

  @@map("stores")
}

enum StoreType {
  FEED
  MEDICATION
  EQUIPMENT
  PACKAGING
  GENERAL
}

model InventoryItem {
  id              String        @id @default(uuid())
  storeId         String
  tenantId        String
  name            String
  category        ItemCategory
  unit            String        // kg, litres, pieces, crates
  currentStock    Decimal       @db.Decimal(12,2)
  reorderLevel    Decimal       @db.Decimal(10,2)
  maxStock        Decimal?      @db.Decimal(12,2)
  costPerUnit     Decimal       @db.Decimal(10,4)
  currency        Currency      @default(NGN)
  supplierId      String?
  batchNumber     String?
  expiryDate      DateTime?     @db.Date
  storageCondition String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  store         Store           @relation(fields: [storeId], references: [id])
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  receipts      StoreReceipt[]  @relation("ItemReceipts")
  issuances     StoreIssuance[] @relation("ItemIssuances")

  @@map("inventory_items")
}

enum ItemCategory {
  FEED
  VACCINE
  MEDICATION
  DISINFECTANT
  EQUIPMENT
  PACKAGING
  SPARE_PARTS
  FUEL
  OTHER
}

model StoreReceipt {
  id              String   @id @default(uuid())
  storeId         String
  receivedById    String
  receiptDate     DateTime @db.Date
  referenceNumber String?  // PO number or delivery note
  supplierId      String?
  feedInventoryId String?
  inventoryItemId String?
  quantityReceived Decimal @db.Decimal(12,2)
  unitCost        Decimal  @db.Decimal(10,4)
  currency        Currency @default(NGN)
  totalCost       Decimal  @db.Decimal(14,2)
  batchNumber     String?
  expiryDate      DateTime? @db.Date
  // QC at receipt
  qualityStatus   QCStatus @default(PENDING)
  qualityNotes    String?
  // Verification
  verifiedById    String?
  verifiedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())

  store         Store          @relation(fields: [storeId], references: [id])
  receivedBy    User           @relation(fields: [receivedById], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  feedInventory FeedInventory? @relation("FeedReceipts", fields: [feedInventoryId], references: [id])
  inventoryItem InventoryItem? @relation("ItemReceipts", fields: [inventoryItemId], references: [id])

  @@map("store_receipts")
}

model StoreIssuance {
  id              String   @id @default(uuid())
  storeId         String
  penSectionId    String?
  issuedById      String
  issuanceDate    DateTime @db.Date
  feedInventoryId String?
  inventoryItemId String?
  quantityIssued  Decimal  @db.Decimal(12,2)
  purpose         String?
  requestedById   String?
  notes           String?
  createdAt       DateTime @default(now())

  store         Store          @relation(fields: [storeId], references: [id])
  penSection    PenSection?    @relation(fields: [penSectionId], references: [id])
  issuedBy      User           @relation(fields: [issuedById], references: [id])
  feedInventory FeedInventory? @relation("FeedIssuances", fields: [feedInventoryId], references: [id])
  inventoryItem InventoryItem? @relation("ItemIssuances", fields: [inventoryItemId], references: [id])

  @@map("store_issuances")
}

// ============================================================================
// MODULE 5 — PROCUREMENT & PURCHASE ORDERS
// ============================================================================

model Supplier {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  supplierType SupplierType @default(FEED)
  contactName  String?
  phone        String?
  email        String?
  address      String?
  taxId        String?
  bankName     String?
  bankAccount  String?
  paymentTerms String?  // e.g. "Net 30"
  rating       Int?     // 1-5
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  feedInventory        FeedInventory[]
  inventoryItems       InventoryItem[]
  storeReceipts        StoreReceipt[]
  purchaseOrders       PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]

  @@map("suppliers")
}

enum SupplierType {
  FEED
  MEDICATION
  EQUIPMENT
  CHICKS
  PACKAGING
  SERVICES
  OTHER
}

model PurchaseRequisition {
  id              String   @id @default(uuid())
  tenantId        String
  requestedById   String
  itemDescription String
  quantity        Decimal  @db.Decimal(12,2)
  unit            String
  estimatedCost   Decimal? @db.Decimal(14,2)
  currency        Currency @default(NGN)
  urgency         Urgency  @default(NORMAL)
  supplierId      String?
  justification   String?
  status          PRStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  purchaseOrderId String?
  createdAt       DateTime @default(now())

  requestedBy   User      @relation(fields: [requestedById], references: [id])
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_requisitions")
}

enum PRStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED_TO_PO
}

enum Urgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model PurchaseOrder {
  id            String    @id @default(uuid())
  tenantId      String
  poNumber      String
  supplierId    String
  createdById   String
  approvedById  String?
  approvedAt    DateTime?
  orderDate     DateTime  @db.Date
  expectedDelivery DateTime? @db.Date
  actualDelivery DateTime? @db.Date
  status        POStatus  @default(DRAFT)
  subtotal      Decimal   @db.Decimal(14,2)
  taxAmount     Decimal   @db.Decimal(14,2) @default(0)
  totalAmount   Decimal   @db.Decimal(14,2)
  currency      Currency  @default(NGN)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier             Supplier              @relation(fields: [supplierId], references: [id])
  createdBy            User                  @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy           User?                 @relation("POApprovedBy", fields: [approvedById], references: [id])
  lineItems            POLineItem[]
  purchaseRequisitions PurchaseRequisition[]
  payments             Payment[]

  @@unique([tenantId, poNumber])
  @@map("purchase_orders")
}

model POLineItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  description     String
  quantity        Decimal @db.Decimal(12,2)
  unit            String
  unitPrice       Decimal @db.Decimal(10,4)
  totalPrice      Decimal @db.Decimal(14,2)
  receivedQty     Decimal @db.Decimal(12,2) @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("po_line_items")
}

enum POStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

