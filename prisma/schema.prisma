}

// ============================================================================
// MODULE 8 — SALES & CUSTOMER MANAGEMENT
// ============================================================================

model Customer {
  id            String       @id @default(uuid())
  tenantId      String
  customerType  CustomerType
  name          String
  contactName   String?
  phone         String?
  email         String?
  address       String?
  taxId         String?
  // B2B fields
  companyName   String?
  creditLimit   Decimal?     @db.Decimal(14,2)
  paymentTerms  String?      // "Cash", "Net 7", "Net 30"
  currency      Currency     @default(NGN)
  isActive      Boolean      @default(true)
  notes         String?
  createdAt     DateTime     @default(now())

  salesOrders SalesOrder[]

  @@map("customers")
}

enum CustomerType {
  B2C   // direct consumer
  B2B   // business buyer
  OFFTAKER  // contracted bulk buyer
}

model SalesOrder {
  id            String        @id @default(uuid())
  tenantId      String
  orderNumber   String
  customerId    String
  soldById      String
  orderDate     DateTime      @db.Date
  deliveryDate  DateTime?     @db.Date
  orderType     SalesOrderType
  status        SalesOrderStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(14,2)
  discountAmount Decimal      @db.Decimal(14,2) @default(0)
  taxAmount     Decimal       @db.Decimal(14,2) @default(0)
  totalAmount   Decimal       @db.Decimal(14,2)
  currency      Currency      @default(NGN)
  paymentStatus PaymentStatus @default(UNPAID)
  deliveryAddress String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer   Customer        @relation(fields: [customerId], references: [id])
  soldBy     User            @relation(fields: [soldById], references: [id])
  lineItems  SalesOrderItem[]
  payments   Payment[]

  @@unique([tenantId, orderNumber])
  @@map("sales_orders")
}

model SalesOrderItem {
  id            String       @id @default(uuid())
  salesOrderId  String
  productType   ProductType
  flockId       String?      // which flock this came from
  description   String
  quantity      Decimal      @db.Decimal(12,2)
  unit          String       // crates, kg, pieces
  unitPrice     Decimal      @db.Decimal(10,4)
  totalPrice    Decimal      @db.Decimal(14,2)
  // Egg grading (if eggs)
  eggGrade      String?      // A, B
  // Broiler grading (if birds)
  weightGrade   String?      // Grade 1, 2, 3

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  flock      Flock?     @relation(fields: [flockId], references: [id])

  @@map("sales_order_items")
}

enum ProductType {
  EGGS
  BROILER_LIVE
  BROILER_DRESSED
  SPENT_HEN
  MANURE
  OTHER
}

enum SalesOrderType {
  CASH_SALE
  CREDIT_SALE
  CONTRACT
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PACKED
  DELIVERED
  INVOICED
  COMPLETED
  CANCELLED
}

