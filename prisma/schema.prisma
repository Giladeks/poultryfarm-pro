// MODULE 9 — ACCOUNTS & FINANCIAL MANAGEMENT
// ============================================================================

model Account {
  id          String      @id @default(uuid())
  tenantId    String
  code        String      // chart of accounts code e.g. "5001"
  name        String      // e.g. "Feed Costs"
  accountType AccountType
  currency    Currency    @default(NGN)
  balance     Decimal     @db.Decimal(14,2) @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  journalEntries JournalEntryLine[]

  @@unique([tenantId, code])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model JournalEntry {
  id          String   @id @default(uuid())
  tenantId    String
  reference   String
  description String
  entryDate   DateTime @db.Date
  currency    Currency @default(NGN)
  totalDebit  Decimal  @db.Decimal(14,2)
  totalCredit Decimal  @db.Decimal(14,2)
  createdById String
  createdAt   DateTime @default(now())

  lines JournalEntryLine[]

  @@map("journal_entries")
}

model JournalEntryLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debitAmount    Decimal @db.Decimal(14,2) @default(0)
  creditAmount   Decimal @db.Decimal(14,2) @default(0)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@map("journal_entry_lines")
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String
  paymentDate     DateTime      @db.Date
  direction       PaymentDirection  // INFLOW or OUTFLOW
  amount          Decimal       @db.Decimal(14,2)
  currency        Currency      @default(NGN)
  paymentMethod   PaymentMethod
  reference       String?
  // Links to source
  salesOrderId    String?
  purchaseOrderId String?
  payrollBatchId  String?
  description     String
  recordedById    String
  createdAt       DateTime      @default(now())

  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  recordedBy    User           @relation(fields: [recordedById], references: [id])

  @@map("payments")
}

enum PaymentDirection {
  INFLOW
  OUTFLOW
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CARD
  MOBILE_MONEY
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  REFUNDED
}

model Budget {
  id          String   @id @default(uuid())
  tenantId    String
  farmId      String?
  name        String
  period      String   // e.g. "2026-Q1", "2026-ANNUAL"
  currency    Currency @default(NGN)
  status      BudgetStatus @default(DRAFT)
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  lineItems BudgetLineItem[]

  @@map("budgets")
}

model BudgetLineItem {
  id          String      @id @default(uuid())
  budgetId    String
  accountCode String
  description String
  budgetedAmount Decimal  @db.Decimal(14,2)
  actualAmount   Decimal  @db.Decimal(14,2) @default(0)
  variance       Decimal  @db.Decimal(14,2) @default(0)

  budget Budget @relation(fields: [budgetId], references: [id])

  @@map("budget_line_items")
}

enum BudgetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ACTIVE
  CLOSED
}

