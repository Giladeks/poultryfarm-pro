  maintenanceRequest  MaintenanceRequest?  @relation(fields: [maintenanceRequestId], references: [id])
  assignedTo          User                 @relation("WOAssignedTo", fields: [assignedToId], references: [id])
  createdBy           User                 @relation("WOCreatedBy", fields: [createdById], references: [id])

  @@map("work_orders")
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

// ============================================================================
// MODULE 12 — VERIFICATION & RECONCILIATION
