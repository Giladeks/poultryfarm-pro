// ============================================================================
// MODULE 13 — HATCHERY (add-on module)
// ============================================================================

model HatchBatch {
  id              String      @id @default(uuid())
  tenantId        String
  batchCode       String
  parentFlockId   String?     // breeder flock that produced the eggs
  eggCount        Int
  settingDate     DateTime    @db.Date
  firstCandlingDate DateTime? @db.Date
  secondCandlingDate DateTime? @db.Date
  expectedHatch   DateTime    @db.Date
  actualHatch     DateTime?   @db.Date
  // Candling results
  fertilizedCount    Int?
  unfertilizedCount  Int?
  earlyDeadCount     Int?
  // Hatch results
  chicksHatched      Int?
  chicksRejected     Int?
  hatchRatePct       Decimal?  @db.Decimal(5,2)
  fertilityRatePct   Decimal?  @db.Decimal(5,2)
  // Placement
  chicksPlaced       Int?
  placementFlockId   String?   // flock where chicks were placed
  status             HatchStatus @default(INCUBATING)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  incubatorReadings IncubatorReading[]

  @@unique([tenantId, batchCode])
  @@map("hatch_batches")
}

model IncubatorReading {
  id            String   @id @default(uuid())
  hatchBatchId  String
  readingTime   DateTime
  temperatureC  Decimal  @db.Decimal(5,2)
  humidityPct   Decimal  @db.Decimal(5,2)
  co2Ppm        Decimal? @db.Decimal(7,2)
  recordedById  String
  inSpec        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())

  hatchBatch HatchBatch @relation(fields: [hatchBatchId], references: [id])

  @@map("incubator_readings")
}

enum HatchStatus {
  INCUBATING
  FIRST_CANDLING
  SECOND_CANDLING
  HATCHING
  COMPLETED
  FAILED
}

// ============================================================================
// MODULE 14 — REPORTING (stored report snapshots)
// ============================================================================

model Report {
  id           String     @id @default(uuid())
  tenantId     String
  reportType   ReportType
  title        String
  period       String     // e.g. "2026-03", "2026-W12"
  parameters   Json?      // filters used to generate
  data         Json?      // cached report data
  status       ReportStatus @default(PENDING)
  generatedById String
  generatedAt  DateTime?
  fileUrl      String?    // if exported to PDF/CSV
  createdAt    DateTime   @default(now())

  @@map("reports")
}

enum ReportType {
  DAILY_PRODUCTION
  WEEKLY_FARM
  MONTHLY_FINANCIAL
  FEED_EFFICIENCY
  MORTALITY_ANALYSIS
  LAYER_PERFORMANCE
  BROILER_PERFORMANCE
  COMPLIANCE
  CUSTOM
}

enum ReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

// ============================================================================
// MODULE 15 — NOTIFICATIONS & ALERTS ENGINE
// ============================================================================

model AlertRule {
  id            String    @id @default(uuid())
  tenantId      String
  name          String
  module        String    // "pen_ops", "feed", "health", etc.
  metric        String    // "mortality_rate", "laying_rate", etc.
  operator      String    // "gt", "lt", "eq"
  threshold     Decimal   @db.Decimal(10,4)
  severity      AlertSeverity @default(WARNING)
  notifyRoles   String[]  // array of UserRole strings
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("alert_rules")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Notification {
  id          String           @id @default(uuid())
  tenantId    String
  recipientId String
  senderId    String?
  type        NotificationType
  title       String
  message     String
  data        Json?            // extra context e.g. { flockId, penId }
  channel     NotificationChannel @default(IN_APP)
  isRead      Boolean          @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime         @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  recipient User    @relation("NotificationRecipient", fields: [recipientId], references: [id])
  sender    User?   @relation("NotificationSender", fields: [senderId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  ALERT
  TASK_ASSIGNED
  TASK_OVERDUE
  REPORT_SUBMITTED
  REPORT_APPROVED
  REPORT_REJECTED
  LOW_STOCK
  VACCINATION_DUE
  MORTALITY_SPIKE
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

// ============================================================================
// MODULE 16 — AUDIT & COMPLIANCE
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  action      AuditAction
  entityType  String   // model name e.g. "Flock", "User"
  entityId    String
  changes     Json?    // { before: {}, after: {} }
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  ROLE_CHANGE
  PASSWORD_CHANGE
}

