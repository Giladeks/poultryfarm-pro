enum VerificationType {
  DAILY_PRODUCTION
  FEED_RECEIPT
  INVENTORY_COUNT
  FINANCIAL_RECORD
  MORTALITY_REPORT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  DISCREPANCY_FOUND
  ESCALATED
  RESOLVED
