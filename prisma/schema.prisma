model PaymentReminder {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId          String
  invoiceType       String
  sentAt            DateTime @default(now()) @db.Timestamp(6)
  sentById          String
  channel           String
  message           String?
  salesInvoiceId    String?
  supplierInvoiceId String?
  sentBy            User     @relation(fields: [sentById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceType, salesInvoiceId], map: "payment_reminders_invoiceType_salesId_idx")
  @@index([invoiceType, supplierInvoiceId], map: "payment_reminders_invoiceType_suppId_idx")
  @@index([salesInvoiceId])
  @@index([supplierInvoiceId])
  @@index([tenantId])
  @@map("payment_reminders")
}

model BankTransaction {
  id                       String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId                 String
  txDate                   DateTime         @db.Date
  description              String
  reference                String?
  amount                   Decimal          @db.Decimal(14, 2)
  currency                 String           @default("NGN")
  bankAccount              String?
  source                   String           @default("MANUAL")
  matchedAt                DateTime?        @db.Timestamptz(6)
  matchedById              String?
  matchedSalesInvoiceId    String?
  matchedSupplierInvoiceId String?
  createdById              String
  createdAt                DateTime         @default(now()) @db.Timestamptz(6)
  createdBy                User             @relation("BankTxCreatedBy", fields: [createdById], references: [id], onUpdate: NoAction)
  matchedBy                User?            @relation("BankTxMatchedBy", fields: [matchedById], references: [id], onUpdate: NoAction)
  matchedSalesInvoice      SalesInvoice?    @relation("BankTxSalesInvoice", fields: [matchedSalesInvoiceId], references: [id], onUpdate: NoAction)
  matchedSupplierInvoice   SupplierInvoice? @relation("BankTxSupplierInvoice", fields: [matchedSupplierInvoiceId], references: [id], onUpdate: NoAction)

  @@index([tenantId])
  @@index([txDate])
  @@index([matchedAt])
  @@map("bank_transactions")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model weight_samples {
  id            String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId      String
  flockId       String
  penSectionId  String?
  sampleDate    DateTime    @db.Date
  sampleCount   Int
  meanWeightG   Decimal     @db.Decimal(8, 1)
  minWeightG    Decimal?    @db.Decimal(8, 1)
  maxWeightG    Decimal?    @db.Decimal(8, 1)
  uniformityPct Decimal?    @db.Decimal(5, 2)
  estimatedFCR  Decimal?    @db.Decimal(6, 3)
  recordedById  String
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @default(now()) @db.Timestamptz(6)
  flocks        Flock       @relation(fields: [flockId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pen_sections  PenSection? @relation(fields: [penSectionId], references: [id], onUpdate: NoAction)
  users         User        @relation(fields: [recordedById], references: [id], onUpdate: NoAction)

  @@index([flockId])
  @@index([penSectionId])
  @@index([sampleDate(sort: Desc)])
  @@index([tenantId])
  @@index([tenantId, sampleDate(sort: Desc)])
}

