  storeDiscrepancyNotes     String?          @map("store_discrepancy_notes")
  disposalVerifiedById      String?          @map("disposal_verified_by_id")
  disposalVerifiedAt        DateTime?        @map("disposal_verified_at") @db.Timestamptz(6)
  disposalVerificationNotes String?          @map("disposal_verification_notes")
  mortalityRecordId         String?          @map("mortality_record_id")
  storeReceiptId            String?          @map("store_receipt_id")
  cleaningTaskId            String?          @map("cleaning_task_id")
  createdAt                 DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  cleaningTask              Task?            @relation(fields: [cleaningTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  disposalVerifiedBy        User?            @relation("flock_lifecycle_events_disposal_verified_by_idTousers", fields: [disposalVerifiedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  flock                     Flock            @relation(fields: [flockId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mortalityRecord           MortalityRecord? @relation(fields: [mortalityRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  penSection                PenSection       @relation(fields: [penSectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy                User?            @relation("flock_lifecycle_events_reviewed_by_idTousers", fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  storeAcknowledgedBy       User?            @relation("flock_lifecycle_events_store_acknowledged_by_idTousers", fields: [storeAcknowledgedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  store                     Store?           @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submittedBy               User             @relation("flock_lifecycle_events_submitted_by_idTousers", fields: [submittedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([flockId], map: "idx_fle_flock")
  @@index([submittedById], map: "idx_fle_submitted_by")
  @@index([tenantId, status], map: "idx_fle_tenant_status")
  @@map("flock_lifecycle_events")
}

