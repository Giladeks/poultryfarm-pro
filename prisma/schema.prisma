// ============================================================================
// MODULE 11 — MAINTENANCE & ASSETS
// ============================================================================

model Asset {
  id               String      @id @default(uuid())
  tenantId         String
  farmId           String?
  assetCode        String
  name             String
  category         AssetCategory
  description      String?
  location         String?
  serialNumber     String?
  manufacturer     String?
  model            String?
  purchaseDate     DateTime?   @db.Date
  purchaseCost     Decimal?    @db.Decimal(14,2)
  currency         Currency    @default(NGN)
  currentValue     Decimal?    @db.Decimal(14,2)
  depreciationRate Decimal?    @db.Decimal(5,2)  // % per year
  warrantyExpiry   DateTime?   @db.Date
