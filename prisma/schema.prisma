  acknowledgedById                                                        String?
  status                                                                  FeedChangeRequestStatus @default(DRAFT)
  fromFeedInventoryId                                                     String
  fromStoreId                                                             String
  returnQtyKg                                                             Decimal?                @db.Decimal(10, 2)
  returnBags                                                              Int?
  returnedActualKg                                                        Decimal?                @db.Decimal(10, 2)
  returnStoreReceiptId                                                    String?
  toFeedInventoryId                                                       String
  toStoreId                                                               String
  requestedQtyKg                                                          Decimal?                @db.Decimal(10, 2)
  requestedBags                                                           Int?
  issuedQtyKg                                                             Decimal?                @db.Decimal(10, 2)
  issuedBags                                                              Int?
  acknowledgedQtyKg                                                       Decimal?                @db.Decimal(10, 2)
  newFeedIssuanceId                                                       String?
  effectiveDate                                                           DateTime                @db.Date
  reason                                                                  FeedChangeReason        @default(AGE_TRANSITION)
  notes                                                                   String?
  fmNotes                                                                 String?
  smNotes                                                                 String?
  pmAckNotes                                                              String?
  submittedAt                                                             DateTime?               @db.Timestamptz(6)
  approvedAt                                                              DateTime?               @db.Timestamptz(6)
  rejectedAt                                                              DateTime?               @db.Timestamptz(6)
  executedAt                                                              DateTime?               @db.Timestamptz(6)
  acknowledgedAt                                                          DateTime?               @db.Timestamptz(6)
  createdAt                                                               DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt                                                               DateTime                @default(now()) @db.Timestamptz(6)
  flocks                                                                  Flock                   @relation(fields: [flockId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fcr_flock")
  feed_inventory_feed_change_requests_fromFeedInventoryIdTofeed_inventory FeedInventory           @relation("feed_change_requests_fromFeedInventoryIdTofeed_inventory", fields: [fromFeedInventoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fcr_from_inv")
  pen_sections                                                            PenSection              @relation(fields: [penSectionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fcr_section")
  tenants                                                                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fcr_tenant")
  feed_inventory_feed_change_requests_toFeedInventoryIdTofeed_inventory   FeedInventory           @relation("feed_change_requests_toFeedInventoryIdTofeed_inventory", fields: [toFeedInventoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fcr_to_inv")

  @@index([flockId], map: "idx_fcr_flock")
  @@index([penSectionId], map: "idx_fcr_section")
  @@index([status], map: "idx_fcr_status")
  @@index([tenantId], map: "idx_fcr_tenant")
}

model push_subscriptions {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  tenantId  String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @db.Timestamptz(6)
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, endpoint])
  @@index([tenantId], map: "idx_push_subs_tenant")
  @@index([userId], map: "idx_push_subs_user")
  @@map("push_subscriptions")
}

