  totalAmount      Decimal               @default(0) @db.Decimal(14, 2)
  amountPaid       Decimal               @default(0) @db.Decimal(14, 2)
  status           SupplierInvoiceStatus @default(PENDING)
  lineItems        Json                  @default("[]")
  paidAt           DateTime?             @db.Timestamp(6)
  paymentRef       String?
  paymentMethod    String?
