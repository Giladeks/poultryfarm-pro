generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Tenant {
  id                   String                 @id @default(uuid())
  farmName             String
  subdomain            String                 @unique
  country              String                 @db.Char(2)
  timezone             String                 @default("Africa/Lagos")
  defaultCurrency      Currency               @default(NGN)
  secondaryCurrency    Currency?
  exchangeRate         Decimal?               @db.Decimal(10, 4)
  logoUrl              String?
  brandingConfig       Json?
  address              String?
  phone                String?
  email                String?
  status               TenantStatus           @default(TRIAL)
  hasHatchery          Boolean                @default(false)
  hasFeedMill          Boolean                @default(false)
  hasProcessingPlant   Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  settings             Json?                  @default("{}")
  alertRules           AlertRule[]
  auditLogs            AuditLog[]
  farms                Farm[]
  feed_change_requests feed_change_requests[]
  notifications        Notification[]
  subscription         Subscription?
  currencies           TenantCurrency[]
  users                User[]
  plans                Plan[]                 @relation("TenantPlans")

  @@map("tenants")
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  maxBirds      Int
  maxUsers      Int
  maxFarms      Int            @default(1)
  monthlyPrice  Decimal        @db.Decimal(10, 2)
  annualPrice   Decimal        @db.Decimal(10, 2)
  features      Json
  isPublic      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  tenants       Tenant[]       @relation("TenantPlans")

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique
  planId               String
  stripeSubscriptionId String?
  stripeCustomerId     String?
  billingCycle         BillingCycle       @default(MONTHLY)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelledAt          DateTime?
  status               SubscriptionStatus @default(TRIALING)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  plan                 Plan               @relation(fields: [planId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

model TenantCurrency {
  id           String   @id @default(uuid())
  tenantId     String
  currency     Currency
  exchangeRate Decimal  @db.Decimal(10, 4)
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, currency])
  @@map("tenant_currencies")
}

model User {
  id                                                    String                @id @default(uuid())
  tenantId                                              String
  farmId                                                String?
  email                                                 String
  passwordHash                                          String
  firstName                                             String
  lastName                                              String
  phone                                                 String?
  avatarUrl                                             String?
  role                                                  UserRole              @default(PEN_WORKER)
  isActive                                              Boolean               @default(true)
  lastLoginAt                                           DateTime?
  passwordResetToken                                    String?
  passwordResetExpiry                                   DateTime?
  createdAt                                             DateTime              @default(now())
  updatedAt                                             DateTime              @updatedAt
  profilePicUrl                                         String?
  attendanceRecords                                     AttendanceRecord[]
  auditLogs                                             AuditLog[]
  bankTransactionsCreated                               BankTransaction[]     @relation("BankTxCreatedBy")
  bankTransactionsMatched                               BankTransaction[]     @relation("BankTxMatchedBy")
  biosecurityLogs                                       BiosecurityLog[]
  broilerHarvestRecords                                 BroilerHarvest[]
  chick_arrivals                                        chick_arrivals[]
  dailyReportsApproved                                  DailyReport[]         @relation("ReportApprovedBy")
  dailyReports                                          DailyReport[]         @relation("ReportSubmittedBy")
  dailySummaryReviews                                   DailySummary[]        @relation("DailySummaryReviewedBy")
  eggProductionApprovals                                EggProduction[]       @relation("EggProductionApprovedBy")
  eggProductionRecords                                  EggProduction[]
  feedConsumptionApprovals                              FeedConsumption[]     @relation("FeedConsumptionApprovedBy")
  feedConsumptionRecords                                FeedConsumption[]
  feedMillBatches                                       FeedMillBatch[]
  flockLifecycleEventsDisposalVerified                  FlockLifecycleEvent[] @relation("flock_lifecycle_events_disposal_verified_by_idTousers")
  flockLifecycleEventsReviewed                          FlockLifecycleEvent[] @relation("flock_lifecycle_events_reviewed_by_idTousers")
  flockLifecycleEventsStoreAcknowledged                 FlockLifecycleEvent[] @relation("flock_lifecycle_events_store_acknowledged_by_idTousers")
  flockLifecycleEventsSubmitted                         FlockLifecycleEvent[] @relation("flock_lifecycle_events_submitted_by_idTousers")
  flock_transfers_flock_transfers_received_by_idTousers flock_transfers[]     @relation("flock_transfers_received_by_idTousers")
  flock_transfers                                       flock_transfers[]
  healthObservations                                    HealthObservation[]
  investigationsEscalated                               Investigation[]       @relation("InvestigationEscalatedTo")
  investigationsFlagged                                 Investigation[]       @relation("InvestigationFlaggedBy")
  investigationsResolved                                Investigation[]       @relation("InvestigationResolvedBy")
  leaveApprovals                                        LeaveRequest[]        @relation("LeaveApprovedBy")
  leaveRequests                                         LeaveRequest[]        @relation("LeaveRequestedBy")
  maintenanceRequests                                   MaintenanceRequest[]
  medicationLogs                                        MedicationLog[]
  mortalityRecords                                      MortalityRecord[]
  notifications                                         Notification[]        @relation("NotificationRecipient")
  sentNotifications                                     Notification[]        @relation("NotificationSender")
  paymentRemindersSent                                  PaymentReminder[]
  payments                                              Payment[]
  payrollRecords                                        PayrollRecord[]
  penAssignments                                        PenWorkerAssignment[]
  purchaseOrdersApproved                                PurchaseOrder[]       @relation("POApprovedBy")
  purchaseOrders                                        PurchaseOrder[]       @relation("POCreatedBy")
  purchaseRequisitions                                  PurchaseRequisition[]
  push_subscriptions                                    push_subscriptions[]
  qcTests                                               QCTest[]
  salesInvoicesApproved                                 SalesInvoice[]        @relation("SalesInvoiceApprovedBy")
  salesInvoicesCreated                                  SalesInvoice[]        @relation("SalesInvoiceCreatedBy")
  salesInvoicesReconciled                               SalesInvoice[]        @relation("SalesInvoiceReconciledBy")
  salesOrders                                           SalesOrder[]
  staffProfile                                          StaffProfile?
  storeIssuances                                        StoreIssuance[]
  storeReceipts                                         StoreReceipt[]
  supplierInvoicesApproved                              SupplierInvoice[]     @relation("SupplierInvoiceApprovedBy")
  supplierInvoicesCreated                               SupplierInvoice[]     @relation("SupplierInvoiceCreatedBy")
  supplierInvoicesReconciled                            SupplierInvoice[]     @relation("SupplierInvoiceReconciledBy")
  tasksApproved                                         Task[]                @relation("TaskApprovedBy")
  tasksAssigned                                         Task[]                @relation("TaskAssignedTo")
  tasksCreated                                          Task[]                @relation("TaskCreatedBy")
  temperature_logs                                      temperature_logs[]
  farm                                                  Farm?                 @relation(fields: [farmId], references: [id])
  tenant                                                Tenant                @relation(fields: [tenantId], references: [id])
  vaccinationsAdministered                              Vaccination[]
  verificationsEscalated                                Verification[]        @relation("VerificationEscalatedTo")
  verificationsResolved                                 Verification[]        @relation("VerificationResolvedBy")
  verifications                                         Verification[]        @relation("VerificationVerifiedBy")
  vetVisits                                             VetVisit[]
  waterMeterReadings                                    WaterMeterReading[]
  weightRecords                                         WeightRecord[]
  weight_samples                                        weight_samples[]
  workOrders                                            WorkOrder[]           @relation("WOAssignedTo")
  workOrdersCreated                                     WorkOrder[]           @relation("WOCreatedBy")

  @@unique([tenantId, email])
  @@map("users")
}

model PenWorkerAssignment {
  id           String     @id @default(uuid())
  userId       String
  penSectionId String
  assignedAt   DateTime   @default(now())
  isActive     Boolean    @default(true)
  penSection   PenSection @relation(fields: [penSectionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, penSectionId])
  @@map("pen_worker_assignments")
}

model Farm {
  id                String             @id @default(uuid())
  tenantId          String
  name              String
  location          String?
  address           String?
  phone             String?
  email             String?
  managerId         String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  autoSummaryTime   String             @default("19:00")
  dailyReports      DailyReport[]
  dailySummaries    DailySummary[]
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  feedMillBatches   FeedMillBatch[]
  pens              Pen[]
  productionTargets ProductionTarget[]
  stores            Store[]
  users             User[]

  @@map("farms")
}

model Pen {
  id                    String                  @id @default(uuid())
  farmId                String
  name                  String
  operationType         PenOperationType
  capacity              Int
  location              String?
  buildYear             Int?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  penPurpose            String                  @default("PRODUCTION")
  egg_inventory_balance egg_inventory_balance[]
  egg_store_receipts    egg_store_receipts[]
  sections              PenSection[]
  farm                  Farm                    @relation(fields: [farmId], references: [id])

  @@map("pens")
}

model PenSection {
  id                                                             String                 @id @default(uuid())
  penId                                                          String
  name                                                           String
  capacity                                                       Int
  isActive                                                       Boolean                @default(true)
  broilerHarvests                                                BroilerHarvest[]
  chick_arrivals                                                 chick_arrivals[]
  dailyReports                                                   DailyReport[]
  dailySummaries                                                 DailySummary[]
  eggProduction                                                  EggProduction[]
  egg_store_receipts                                             egg_store_receipts[]
  feed_change_requests                                           feed_change_requests[]
  feedConsumption                                                FeedConsumption[]
  flockLifecycleEvents                                           FlockLifecycleEvent[]
  flock_transfers_flock_transfers_fromPenSectionIdTopen_sections flock_transfers[]      @relation("flock_transfers_fromPenSectionIdTopen_sections")
  flock_transfers_flock_transfers_toPenSectionIdTopen_sections   flock_transfers[]      @relation("flock_transfers_toPenSectionIdTopen_sections")
  flocks                                                         Flock[]
  healthObservations                                             HealthObservation[]
  mortalityRecords                                               MortalityRecord[]
  pen                                                            Pen                    @relation(fields: [penId], references: [id])
  workerAssignments                                              PenWorkerAssignment[]
  storeIssuances                                                 StoreIssuance[]
  tasks                                                          Task[]
  temperature_logs                                               temperature_logs[]
  waterMeterReadings                                             WaterMeterReading[]
  weightRecords                                                  WeightRecord[]
  weight_samples                                                 weight_samples[]

  @@map("pen_sections")
}

model Flock {
  id                      String                 @id @default(uuid())
  tenantId                String
  penSectionId            String
  batchCode               String
  operationType           PenOperationType
  breed                   String
  dateOfPlacement         DateTime               @db.Date
  initialCount            Int
  currentCount            Int
  source                  FlockSource            @default(PURCHASED)
  purchaseCost            Decimal?               @db.Decimal(14, 2)
  purchaseCurrency        Currency               @default(NGN)
  status                  FlockStatus            @default(ACTIVE)
  notes                   String?
  expectedLayingStartDate DateTime?              @db.Date
  peakLayingRatePct       Decimal?               @db.Decimal(5, 2)
  depletionDate           DateTime?              @db.Date
  targetWeightG           Decimal?               @db.Decimal(8, 2)
  expectedHarvestDate     DateTime?              @db.Date
  targetFCR               Decimal?               @db.Decimal(4, 2)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  stage                   String                 @default("PRODUCTION")
  stageUpdatedAt          DateTime?              @db.Timestamptz(6)
  broodingEndDate         DateTime?              @db.Date
  rearingStartDate        DateTime?              @db.Date
  pointOfLayDate          DateTime?              @db.Date
  originalPenSectionId    String?
  depletionDisposition    String?                @db.VarChar(20)
  broilerHarvests         BroilerHarvest[]
  chick_arrivals          chick_arrivals[]
  dailyReports            DailyReport[]
  eggProduction           EggProduction[]
  feed_change_requests    feed_change_requests[]
  feedConsumption         FeedConsumption[]
  flockLifecycleEvents    FlockLifecycleEvent[]
  flock_transfers         flock_transfers[]
  penSection              PenSection             @relation(fields: [penSectionId], references: [id])
  healthObservations      HealthObservation[]
  medicationLogs          MedicationLog[]
  mortalityRecords        MortalityRecord[]
  salesOrderItems         SalesOrderItem[]
  vaccinations            Vaccination[]
  waterMeterReadings      WaterMeterReading[]
  weightRecords           WeightRecord[]
  weight_samples          weight_samples[]

  @@unique([tenantId, batchCode])
  @@index([penSectionId, stage], map: "flocks_stage_penSectionId_idx")
  @@index([tenantId, stage], map: "flocks_stage_tenantId_idx")
  @@map("flocks")
}

model EggProduction {
  id                  String              @id @default(uuid())
  flockId             String
  penSectionId        String
  collectionDate      DateTime            @db.Date
  totalEggs           Int
  gradeACount_old     Int                 @default(0)
  gradeBCount_old     Int                 @default(0)
  crackedCount        Int                 @default(0)
  dirtyCount          Int                 @default(0)
  layingRatePct       Decimal             @db.Decimal(5, 2)
  cratesCount         Int?
  recordedById        String
  approvedById        String?
  approvedAt          DateTime?
  submissionStatus    SubmissionStatus    @default(PENDING)
  notes               String?
  createdAt           DateTime            @default(now())
  rejectionReason     String?
  collectionSession   Int                 @default(1)
  cratesCollected     Int?
  looseEggs           Int                 @default(0)
  gradeBCrates        Int?
  gradeBLoose         Int?
  crackedConfirmed    Int?
  gradeBCount         Int?
  gradeACount         Int?
  gradeAPct           Decimal?            @db.Decimal(5, 2)
  cratesCollected_new Int?
  updatedAt           DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  birdsAtCollection   Int?
  approvedBy          User?               @relation("EggProductionApprovedBy", fields: [approvedById], references: [id], onUpdate: NoAction)
  flock               Flock               @relation(fields: [flockId], references: [id])
  penSection          PenSection          @relation(fields: [penSectionId], references: [id])
  recordedBy          User                @relation(fields: [recordedById], references: [id])
  egg_store_receipts  egg_store_receipts?

  @@map("egg_production")
}

model WeightRecord {
  id                String     @id @default(uuid())
  flockId           String
  penSectionId      String
  recordDate        DateTime   @db.Date
  ageInDays         Int
  sampleSize        Int
  avgWeightG        Decimal    @db.Decimal(8, 2)
  minWeightG        Decimal    @db.Decimal(8, 2)
  maxWeightG        Decimal    @db.Decimal(8, 2)
  uniformityPct     Decimal?   @db.Decimal(5, 2)
  recordedById      String
  notes             String?
  createdAt         DateTime   @default(now())
  individualWeights Json?
  flock             Flock      @relation(fields: [flockId], references: [id])
  penSection        PenSection @relation(fields: [penSectionId], references: [id])
  recordedBy        User       @relation(fields: [recordedById], references: [id])

  @@map("weight_records")
}

model BroilerHarvest {
  id                 String           @id @default(uuid())
  flockId            String
  penSectionId       String
  harvestDate        DateTime         @db.Date
  birdsHarvested     Int
  birdsRejected      Int              @default(0)
  totalLiveWeightKg  Decimal          @db.Decimal(10, 2)
  avgLiveWeightG     Decimal          @db.Decimal(8, 2)
  totalDressWeightKg Decimal?         @db.Decimal(10, 2)
  dressingPct        Decimal?         @db.Decimal(5, 2)
  grade1Count        Int              @default(0)
  grade2Count        Int              @default(0)
  grade3Count        Int              @default(0)
  finalFCR           Decimal?         @db.Decimal(5, 3)
  totalFeedKg        Decimal?         @db.Decimal(10, 2)
  pricePerKg         Decimal?         @db.Decimal(10, 2)
  totalRevenue       Decimal?         @db.Decimal(14, 2)
  currency           Currency         @default(NGN)
  recordedById       String
  approvedById       String?
  approvedAt         DateTime?
  submissionStatus   SubmissionStatus @default(PENDING)
  notes              String?
  createdAt          DateTime         @default(now())
  flock              Flock            @relation(fields: [flockId], references: [id])
  penSection         PenSection       @relation(fields: [penSectionId], references: [id])
  recordedBy         User             @relation(fields: [recordedById], references: [id])

  @@map("broiler_harvests")
}

model MortalityRecord {
  id                   String                @id @default(uuid())
  flockId              String
  penSectionId         String
  recordedById         String
  recordDate           DateTime              @db.Date
  count                Int
  causeCode            MortalityCause        @default(UNKNOWN)
  notes                String?
  photoUrl             String?
  approvedById         String?
  approvedAt           DateTime?
  submissionStatus     SubmissionStatus      @default(PENDING)
  createdAt            DateTime              @default(now())
  rejectionReason      String?
  flockLifecycleEvents FlockLifecycleEvent[]
  flock                Flock                 @relation(fields: [flockId], references: [id])
  penSection           PenSection            @relation(fields: [penSectionId], references: [id])
  recordedBy           User                  @relation(fields: [recordedById], references: [id])

  @@map("mortality_records")
}

model DailyReport {
  id             String           @id @default(uuid())
  farmId         String
  penSectionId   String
  flockId        String?
  reportDate     DateTime         @db.Date
  operationType  PenOperationType
  totalMortality Int              @default(0)
  totalFeedKg    Decimal          @default(0) @db.Decimal(10, 2)
  totalEggs      Int?
  layingRatePct  Decimal?         @db.Decimal(5, 2)
  avgWeightG     Decimal?         @db.Decimal(8, 2)
  observations   String?
  submittedById  String
  submittedAt    DateTime         @default(now())
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  status         SubmissionStatus @default(PENDING)
  approvedBy     User?            @relation("ReportApprovedBy", fields: [approvedById], references: [id])
  farm           Farm             @relation(fields: [farmId], references: [id])
  flock          Flock?           @relation(fields: [flockId], references: [id])
  penSection     PenSection       @relation(fields: [penSectionId], references: [id])
  submittedBy    User             @relation("ReportSubmittedBy", fields: [submittedById], references: [id])

  @@unique([penSectionId, reportDate])
  @@map("daily_reports")
}

model FeedFormula {
  id            String                  @id @default(uuid())
  tenantId      String
  name          String
  birdType      PenOperationType
  ageWeekMin    Int
  ageWeekMax    Int
  description   String?
  isActive      Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  ingredients   FeedFormulaIngredient[]
  feedInventory FeedInventory[]

  @@map("feed_formulas")
}

model FeedFormulaIngredient {
  id            String      @id @default(uuid())
  formulaId     String
  ingredient    String
  percentagePct Decimal     @db.Decimal(5, 2)
  formula       FeedFormula @relation(fields: [formulaId], references: [id])

  @@map("feed_formula_ingredients")
}

model FeedInventory {
  id                                                                            String                 @id @default(uuid())
  tenantId                                                                      String
  storeId                                                                       String
  feedType                                                                      String
  formulaId                                                                     String?
  currentStockKg                                                                Decimal                @db.Decimal(12, 2)
  reorderLevelKg                                                                Decimal                @db.Decimal(10, 2)
  maxStockKg                                                                    Decimal?               @db.Decimal(12, 2)
  costPerKg                                                                     Decimal                @db.Decimal(10, 4)
  currency                                                                      Currency               @default(NGN)
  supplierId                                                                    String?
  batchNumber                                                                   String?
  expiryDate                                                                    DateTime?              @db.Date
  updatedAt                                                                     DateTime               @updatedAt
  createdAt                                                                     DateTime               @default(now())
  bagWeightKg                                                                   Decimal                @default(25) @db.Decimal(6, 2)
  feedPhase                                                                     FeedPhase?
  feed_change_requests_feed_change_requests_fromFeedInventoryIdTofeed_inventory feed_change_requests[] @relation("feed_change_requests_fromFeedInventoryIdTofeed_inventory")
  feed_change_requests_feed_change_requests_toFeedInventoryIdTofeed_inventory   feed_change_requests[] @relation("feed_change_requests_toFeedInventoryIdTofeed_inventory")
  consumption                                                                   FeedConsumption[]
  formula                                                                       FeedFormula?           @relation(fields: [formulaId], references: [id])
  store                                                                         Store                  @relation(fields: [storeId], references: [id])
  supplier                                                                      Supplier?              @relation(fields: [supplierId], references: [id])
  issuances                                                                     StoreIssuance[]        @relation("FeedIssuances")
  storeReceipts                                                                 StoreReceipt[]         @relation("FeedReceipts")

  @@map("feed_inventory")
}

model FeedConsumption {
  id                  String        @id @default(uuid())
  flockId             String
  penSectionId        String
  feedInventoryId     String
  recordedDate        DateTime      @db.Date
  quantityKg          Decimal       @db.Decimal(10, 2)
  gramsPerBird        Decimal?      @db.Decimal(6, 2)
  costAtTime          Decimal       @db.Decimal(10, 4)
  currency            Currency      @default(NGN)
  recordedById        String
  notes               String?
  createdAt           DateTime      @default(now())
  feedTime            DateTime      @default(now()) @db.Timestamptz(6)
  bagsUsed            Int?
  remainingKg         Decimal?      @db.Decimal(6, 2)
  bagWeightKg         Decimal?      @db.Decimal(6, 2)
  approvedById        String?
  approvedAt          DateTime?     @db.Timestamptz(6)
  submissionStatus    String        @default("PENDING")
  rejectionReason     String?
  updatedAt           DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  birdsAtDistribution Int?
  approvedBy          User?         @relation("FeedConsumptionApprovedBy", fields: [approvedById], references: [id], onUpdate: NoAction)
  feedInventory       FeedInventory @relation(fields: [feedInventoryId], references: [id])
  flock               Flock         @relation(fields: [flockId], references: [id])
  penSection          PenSection    @relation(fields: [penSectionId], references: [id])
  recordedBy          User          @relation(fields: [recordedById], references: [id])

  @@map("feed_consumption")
}

model FeedRequisition {
  id                     String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId               String
  requisitionNumber      String
  penSectionId           String?
  flockId                String
  feedInventoryId        String
  storeId                String?
  feedForDate            DateTime              @db.Date
  triggerLogId           String?
  calculatedQtyKg        Decimal               @db.Decimal(10, 2)
  avgConsumptionPerBirdG Decimal?              @db.Decimal(8, 4)
  currentBirdCount       Int?
  calculationDays        Int                   @default(7)
  requestedQtyKg         Decimal?              @db.Decimal(10, 2)
  pmNotes                String?
  submittedById          String?
  submittedAt            DateTime?             @db.Timestamptz(6)
  deviationPct           Decimal?              @db.Decimal(6, 2)
  approvedQtyKg          Decimal?              @db.Decimal(10, 2)
  icNotes                String?
  approvedById           String?
  approvedAt             DateTime?             @db.Timestamptz(6)
  rejectionReason        String?
  rejectedById           String?
  rejectedAt             DateTime?             @db.Timestamptz(6)
  issuedQtyKg            Decimal?              @db.Decimal(10, 2)
  issuedById             String?
  issuedAt               DateTime?             @db.Timestamptz(6)
  storeIssuanceId        String?
  issuanceNotes          String?
  acknowledgedQtyKg      Decimal?              @db.Decimal(10, 2)
  acknowledgedById       String?
  acknowledgedAt         DateTime?             @db.Timestamptz(6)
  discrepancyQtyKg       Decimal?              @db.Decimal(10, 2)
  acknowledgementNotes   String?
  closedById             String?
  closedAt               DateTime?             @db.Timestamptz(6)
  closeNotes             String?
  status                 FeedRequisitionStatus @default(DRAFT)
  createdAt              DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  penId                  String?
  sectionBreakdown       Json?
  totalBagsRequired      Int?
  totalRemainderKg       Decimal?              @db.Decimal(8, 2)

  @@unique([penId, feedInventoryId, feedForDate], map: "feed_requisitions_pen_inventory_date_unique")
  @@unique([tenantId, requisitionNumber], map: "feed_requisitions_tenant_number_unique")
  @@index([feedInventoryId], map: "feed_requisitions_feed_inventory_idx")
  @@index([penId, feedForDate(sort: Desc)], map: "feed_requisitions_pen_id_idx")
  @@index([penSectionId, feedForDate(sort: Desc)], map: "feed_requisitions_pen_section_idx")
  @@index([submittedById], map: "feed_requisitions_submitted_by_idx")
  @@index([tenantId, status], map: "feed_requisitions_tenant_status_idx")
  @@map("feed_requisitions")
}

model WaterMeterReading {
  id             String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId       String
  penSectionId   String
  flockId        String?
  readingDate    DateTime   @db.Date
  meterReading   Decimal    @db.Decimal(12, 2)
  consumptionL   Decimal?   @db.Decimal(12, 2)
  consumptionLPB Decimal?   @db.Decimal(8, 4)
  recordedById   String
