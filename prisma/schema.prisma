model SalesInvoice {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  tenantId         String
  invoiceNumber    String
  customerId       String
  flockId          String?
  farmId           String?
  invoiceDate      DateTime          @db.Date
  dueDate          DateTime          @db.Date
  currency         Currency          @default(NGN)
  exchangeRate     Decimal           @default(1.0) @db.Decimal(12, 6)
  subtotal         Decimal           @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal           @default(0) @db.Decimal(14, 2)
  totalAmount      Decimal           @default(0) @db.Decimal(14, 2)
  amountPaid       Decimal           @default(0) @db.Decimal(14, 2)
  status           InvoiceStatus     @default(DRAFT)
  lineItems        Json              @default("[]")
  paidAt           DateTime?         @db.Timestamp(6)
  paymentRef       String?
  paymentMethod    String?
  reconciledAt     DateTime?         @db.Timestamp(6)
  reconciledById   String?
  notes            String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?         @db.Timestamp(6)
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @updatedAt @db.Timestamp(6)
  bankTransactions BankTransaction[] @relation("BankTxSalesInvoice")
  approvedBy       User?             @relation("SalesInvoiceApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User              @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reconciledBy     User?             @relation("SalesInvoiceReconciledBy", fields: [reconciledById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@index([customerId])
  @@map("sales_invoices")
}

model SupplierInvoice {
